# A.R.I.S Macro Overlay System — Environment Configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── IBKR Gateway ───────────────────────────────────────────────────
# Credentials for IBC automatic login
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password
IBKR_TRADING_MODE=paper             # paper | live
IBKR_PORT=4002                      # 4001=live, 4002=paper
IBKR_CLIENT_ID=1

# ── FRED API ───────────────────────────────────────────────────────
# Get a free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── LSEG / Refinitiv ──────────────────────────────────────────────
# For Hetzner (headless): use "platform" session with RDP credentials
LSEG_APP_KEY=your_lseg_app_key_here
LSEG_SESSION_TYPE=platform          # "desktop" for local Workspace, "platform" for headless
LSEG_USERNAME=your_lseg_rdp_email   # required for platform session
LSEG_PASSWORD=your_lseg_rdp_pass    # required for platform session

# ── Data Source Routing ────────────────────────────────────────────
PRIMARY_PRICE_SOURCE=lseg            # lseg | yfinance
PRIMARY_MACRO_SOURCE=fred            # lseg | fred

# ── Anthropic (Jeffrey Briefing) ──────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Scheduler ─────────────────────────────────────────────────────
# Cron schedule for daily pipeline (default: 4:30 PM ET, Mon-Fri)
# Adjust for your server's timezone. Hetzner is UTC, so 16:30 ET = 20:30 UTC
PIPELINE_SCHEDULE=30 20 * * 1-5

# ── Phase A: Hybrid Alpha ─────────────────────────────────────────
# T6 hybrid = 50% TSMOM continuous ensemble + 50% BSV composite
USE_HYBRID_ALPHA=true               # true = T6 hybrid | false = BSV-only
TSMOM_WEIGHT=0.50                   # weight on TSMOM leg (BSV = 1 - this)

# ── Phase A: Vol-Target Sizing ─────────────────────────────────────
PORTFOLIO_VOL_TARGET=0.12           # annualized portfolio vol target (12%)
VOL_TARGET_WINDOW=63                # trailing window for realized vol (63 ≈ 3 months)
SIGNAL_GROSS_CAP=1.5                # max gross exposure after vol scaling

# ── Phase A: Regime Tilts ──────────────────────────────────────────
APPLY_REGIME_TILTS=true             # apply ISM×CPI quadrant regime overlays

# ── Phase A: Rebalance Gate ────────────────────────────────────────
REBALANCE_FREQ=weekly               # weekly | daily
REBALANCE_WEEKDAY=2                 # 0=Mon … 4=Fri (default: Wed)
TRADE_DEADBAND_PCT=0.02             # skip trade if |new − old| < 2% of gross

# ── Google Sheets (optional, for position tracking) ───────────────
# GSHEET_CREDENTIALS=credentials.json
# GSHEET_SPREADSHEET_ID=your_spreadsheet_id_here
